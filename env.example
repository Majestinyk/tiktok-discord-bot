# 編集者A設定
# EDITOR_A_NAME = Discordの表示名（@なし）
EDITOR_A_NAME=編集者A
EDITOR_A_SHEET=編集者A

# 編集者B設定
EDITOR_B_NAME=編集者B
EDITOR_B_SHEET=編集者B
